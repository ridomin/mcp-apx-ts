# Microsoft Teams Bot Configuration
# Copy this file to .env and fill in your values

# Required
TEAMS_SERVICE_URL=https://smba.trafficmanager.net/teams
TEAMS_BOT_TOKEN=your-bot-client-secret

# Test IDs (optional, tests will skip if not set)
TEST_TENANT_ID=your-tenant-id
TEST_APP_ID=your-app-id
TEST_CONVERSATION_ID=your-conversation-id
TEST_USER_ID=your-user-id
TEST_ACTIVITY_ID=your-activity-id
TEST_MEETING_ID=your-meeting-id
TEST_CONNECTION_NAME=your-oauth-connection
TEST_CHANNEL_ID=your-channel-id
